{
  "name": "vela",
  "productName": "Vela",
  "version": "2.1.399",
  "description": "Mission-first AI Operating Desk with voice, memory, agents, permissions, and review",
  "type": "module",
  "main": "electron/main.cjs",
  "author": {
    "name": "yeyunzhou-26"
  },
  "scripts": {
    "start": "electron .",
    "start:lan": "powershell -ExecutionPolicy Bypass -File scripts/start-lan.ps1 app",
    "start:backend": "node --env-file=.env src/index.js",
    "start:backend:lan": "powershell -ExecutionPolicy Bypass -File scripts/start-lan.ps1 backend",
    "dev": "node --env-file=.env --watch src/index.js",
    "dev:vela": "node ./scripts/serve-vela-preview.mjs",
    "build": "powershell -ExecutionPolicy Bypass -File scripts/prebuild-clean.ps1 && electron-rebuild -f -w better-sqlite3 -v 33.4.11 && electron-builder --win",
    "publish": "electron-builder --win --publish always",
    "postinstall": "electron-builder install-app-deps",
    "test:rule-context": "electron ./src/test-rule-context.js",
    "test:complex-task": "electron ./src/test-complex-task.js",
    "test:relevance": "electron ./src/test-relevance-selection.js",
    "test:section-gate": "node ./src/test-section-gate.js",
    "test:agent-skills": "node ./src/test-agent-skills.js",
    "test:config-upgrade": "node ./src/test-config-upgrade.js",
    "test:vela-mission": "node ./src/test-vela-mission.js",
    "test:vela-web-reader": "node ./src/test-vela-web-reader.js",
    "repair:memories:dry": "electron ./scripts/repair-memory-quality.js",
    "repair:memories": "electron ./scripts/repair-memory-quality.js --apply",
    "probe:config-upgrade": "node ./scripts/probe-config-upgrade.mjs",
    "smoke:tools": "electron ./scripts/smoke-tools.mjs",
    "smoke:brain-ui": "node scripts/smoke-brain-ui.mjs",
    "smoke:social": "electron ./scripts/smoke-social.mjs",
    "smoke:vela-shell": "node scripts/smoke-vela-shell.mjs",
    "smoke:vela-entry": "electron ./scripts/smoke-vela-entry.mjs",
    "smoke:vela-packaged": "node scripts/smoke-vela-packaged.mjs",
    "eval:vela-golden-trace": "node scripts/eval-vela-golden-trace.mjs",
    "eval:vela-memory-recall": "node scripts/eval-vela-memory-recall.mjs",
    "eval:vela-tool-permission": "node scripts/eval-vela-tool-permission.mjs",
    "eval:vela-voice-latency": "node scripts/eval-vela-voice-latency.mjs",
    "eval:vela-review-claim": "node scripts/eval-vela-review-claim.mjs",
    "eval:vela-product-contract": "node scripts/eval-vela-product-contract.mjs",
    "eval:vela-review-slices": "node scripts/eval-vela-review-slices.mjs",
    "eval:vela-polish-readiness": "node scripts/eval-vela-polish-readiness.mjs",
    "check:vela": "npm run test:vela-mission && npm run test:vela-web-reader && npm run smoke:vela-shell && npm run smoke:vela-entry && npm run smoke:vela-packaged && npm run eval:vela-golden-trace && npm run eval:vela-memory-recall && npm run eval:vela-tool-permission && npm run eval:vela-voice-latency && npm run eval:vela-review-claim && npm run eval:vela-product-contract && npm run eval:vela-review-slices && npm run eval:vela-polish-readiness"
  },
  "dependencies": {
    "better-sqlite3": "^12.8.0",
    "d3": "^7.9.0",
    "electron-updater": "^6.3.9",
    "openai": "^6.34.0",
    "wechat-ilink-client": "^0.1.0",
    "ws": "^8.20.1"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.4",
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8",
    "playwright": "^1.59.1"
  },
  "build": {
    "appId": "com.yeyunzhou.vela",
    "productName": "Vela",
    "artifactName": "${productName}-Setup-${version}.${ext}",
    "npmRebuild": false,
    "asar": true,
    "asarUnpack": [
      "**/node_modules/better-sqlite3/**",
      "src/voice/**"
    ],
    "files": [
      "electron/**/*",
      "src/**/*",
      "skills/**/*",
      "scripts/seed-memories.js",
      "index.html",
      "vela.html",
      "dashboard.html",
      "brain.html",
      "brain-ui.html",
      "website.html",
      "systemPrompt.html",
      "activation.html",
      "focus-banner.html",
      "turn-trace.html",
      "build/icon.ico",
      "sandbox/**/*",
      "music/**/*",
      "package.json",
      "!**/*.map",
      "!src/test-*",
      "!src/**/test-*",
      "!scripts/smoke-*.mjs",
      "!src/**/__pycache__/**",
      "!src/**/*.pyc",
      "!**/node_modules/*/{CHANGELOG.md,README.md,readme.md,*.d.ts}",
      "!**/node_modules/.cache",
      "!**/.vscode",
      "!data/**/*"
    ],
    "directories": {
      "buildResources": "build",
      "output": "dist"
    },
    "win": {
      "icon": "build/icon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "deleteAppDataOnUninstall": false,
      "installerHeaderIcon": "build/installerHeaderIcon.ico",
      "installerSidebar": "build/installerSidebar.bmp",
      "uninstallerSidebar": "build/uninstallerSidebar.bmp",
      "createDesktopShortcut": false,
      "createStartMenuShortcut": false,
      "shortcutName": "Vela"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "yeyunzhou-26",
        "repo": "Vela",
        "releaseType": "release"
      }
    ]
  }
}
